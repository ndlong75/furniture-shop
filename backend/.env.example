NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://furnitureuser:furniturepass@localhost:5432/furnituredb
# Set to true only for managed cloud PostgreSQL (AWS RDS, Supabase, etc.)
# Use false for local PostgreSQL on the same server
DATABASE_SSL=false
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:4200

# Required only when running: npm run seed
SEED_ADMIN_PASSWORD=choose-a-strong-admin-password
